{
    "name": "lucaslaurens/assertion",
    "description": "This library contains efficient assertions to test the input and output of your methods. With these assertions, you can greatly reduce the amount of coding needed to write a safe implementation.",
    "keywords": [
        "php",
        "symfony",
        "library",
        "package",
        "pest",
        "unit",
        "test",
        "testing"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Lucas Laurens",
            "email": "lucaslaurens.74@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "LucasLaurens\\Assertion\\": "src/"
        },
        "files": ["src/Functions.php"]
    },
    "autoload-dev": {
        "psr-4": {
        },
        "files": []
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "symfony/console": "^7.4",
        "symfony/var-dumper": "^7.0"
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "platform": {
            "php": "8.5.0"
        },
        "platform-check": false,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "pint": "php vendor/bin/pint",
        "rector": "php vendor/bin/rector",
        "stan": "php vendor/bin/phpstan",
        "pest": "php vendor/bin/pest",
        "cover": [
            "@pint",
            "@rector",
            "@stan",
            "@pest"
        ]
    }
}
